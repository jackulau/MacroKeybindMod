{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "MacroMod — a multi-version Fabric client mod wired to the pure-JVM macro scripting engine.",
  "authors": [
    "MacroMod"
  ],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "dev.macromod.fabric.MacroModClient"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=0.16",
    "fabric-language-kotlin": ">=1.13.0",
    "minecraft": "${minecraft}",
    "java": ">=21"
  }
}
